NODE_ENV=development
PORT=3000
API_PREFIX=api

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=homecare
DB_PASSWORD=homecare_dev
DB_DATABASE=homecare_dev

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=7d

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx

# CORS — comma-separated list of allowed browser origins (production uses this strictly).
# Development also allows http://<private-ip>:5173 for same-Wi‑Fi mobile testing.
CORS_ORIGIN=http://localhost:5173

# Optional bind address (default 0.0.0.0 so phones on LAN can reach the API)
# HOST=0.0.0.0
